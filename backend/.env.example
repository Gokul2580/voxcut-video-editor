# VoxCut Backend Environment Variables

# File Storage
UPLOAD_DIR=./uploads
PROCESSED_DIR=./processed

# Processing Configuration
MAX_VIDEO_SIZE=2147483648  # 2GB in bytes
PROCESSING_TIMEOUT=3600  # seconds

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# FFmpeg Configuration
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Whisper Configuration
WHISPER_MODEL=base
